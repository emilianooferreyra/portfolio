---
import Layout from '../layouts/Layout.astro';
import { projects, experience, stack } from '../data/portfolio';
---

<Layout>
  <!-- Hero -->
  <header class="max-w-4xl mx-auto px-6 py-16 border-b border-black dark:border-white">
    <div class="space-y-4">
      <h1 class="text-4xl font-bold tracking-tight">Emiliano Ferreyra</h1>
      <p class="text-lg text-gray-700 dark:text-gray-300">Frontend Engineer / Full-Stack Developer</p>
      <p class="text-sm text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
        5+ years delivering custom web products across agency, startup, and government environments.
        Focused on React, Next.js, and TypeScript. Currently expanding into Go and full-stack
        architecture while building Ampli, an audio streaming platform from scratch.
        Based in Buenos Aires, available for remote roles.
      </p>
      <div class="flex flex-wrap gap-4 pt-4 text-sm">
        <a href="https://github.com/emilianooferreyra" target="_blank" rel="noopener" class="hover:underline">
          GitHub ↗
        </a>
        <a href="https://linkedin.com/in/emilianooferreyra" target="_blank" rel="noopener" class="hover:underline">
          LinkedIn ↗
        </a>
        <a href="mailto:emilianoferreyraa@gmail.com" class="hover:underline">
          Email ↗
        </a>
      </div>
    </div>
  </header>

  <!-- Projects -->
  <section class="max-w-4xl mx-auto px-6 py-16 border-b border-black dark:border-white">
    <h2 class="text-2xl font-bold mb-12">/ Projects</h2>
    <div class="space-y-16">
      {projects.map((project) => (
        <div class="border-l-2 border-gray-300 dark:border-zinc-700 pl-6">
          <div class="space-y-3">
            <div class="flex justify-between items-start gap-4">
              <div>
                <h3 class="text-xl font-bold">{project.title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">{project.subtitle}</p>
              </div>
              <span class="text-xs text-gray-500 font-bold shrink-0">{project.year}</span>
            </div>
            <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{project.description}</p>
            <div class="flex flex-wrap gap-2 pt-1">
              {project.tech.map((tech) => (
                <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-zinc-800 border border-gray-300 dark:border-zinc-700">{tech}</span>
              ))}
            </div>
            <div class="flex flex-wrap gap-4 pt-2">
              {project.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener" class="text-xs font-bold hover:underline">
                  {link.label} ↗
                </a>
              ))}
              {'caseSlug' in project && (
                <a href={`/cases/${project.caseSlug}`} class="text-xs font-bold hover:underline">
                  Case Study →
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="max-w-4xl mx-auto px-6 py-16 border-b border-black dark:border-white">
    <h2 class="text-2xl font-bold mb-12">/ Experience</h2>
    <div class="space-y-12">
      {experience.map((job) => (
        <div class="border-l-2 border-gray-300 dark:border-zinc-700 pl-6">
          <div class="space-y-3">
            <div class="flex justify-between items-start gap-4">
              <div>
                <h3 class="text-lg font-bold">{job.company}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">{job.role}</p>
              </div>
              <span class="text-xs text-gray-500 shrink-0">{job.period}</span>
            </div>
            <ul class="space-y-1.5 text-sm text-gray-700 dark:text-gray-300">
              {job.highlights.map((highlight) => (
                <li class="flex gap-2">
                  <span class="font-bold shrink-0">•</span>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Core Stack -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-8">/ Core Stack</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-sm">
      <div>
        <h3 class="font-bold dark:text-white mb-3">Preference</h3>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{stack.preference}</p>
      </div>
      <div>
        <h3 class="font-bold dark:text-white mb-3">Exposure</h3>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{stack.exposure}</p>
      </div>
      <div>
        <h3 class="font-bold dark:text-white mb-3">AI Tooling</h3>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{stack.ai}</p>
      </div>
    </div>
  </section>
</Layout>
