---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <header class="mb-12 border-b border-black dark:border-white pb-8">
      <p class="text-xs text-gray-500 mb-2">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h1 class="text-3xl font-bold mb-2">{post.data.title}</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">{post.data.description}</p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-zinc-800 border border-gray-300 dark:border-zinc-700">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <article class="text-sm leading-relaxed">
      <Content />
    </article>

    <div class="mt-16 pt-8 border-t border-black dark:border-white">
      <a href="/blog" class="text-sm font-bold hover:underline">← Back to Blog</a>
    </div>
  </main>
</Layout>
